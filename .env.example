# Copy to `.env.local` and fill in.
# `.env.local` is gitignored by Next.js by default ‚Äî your private key is safe.

# ‚îÄ‚îÄ Deploy script (server-side only ‚Äî never exposed to the browser) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# Used by `npm run deploy` to send the deploy transactions.
PRIVATE_KEY=

# ‚îÄ‚îÄ Studionet contract addresses (default network) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# Filled in automatically by `npm run deploy`. The NEXT_PUBLIC_ prefix means
# they're shipped to the browser, which is fine ‚Äî they're public addresses.
NEXT_PUBLIC_STUDIONET_PITCH_WARS=
NEXT_PUBLIC_STUDIONET_JOKE_WARS=
NEXT_PUBLIC_STUDIONET_EXCUSE_WARS=
NEXT_PUBLIC_STUDIONET_PREDICTION_WARS=
NEXT_PUBLIC_STUDIONET_STORY_WARS=

# ‚îÄ‚îÄ Bradbury testnet contract addresses (already hardcoded in chain.ts) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# Only override if you redeploy. Leave blank otherwise.
# NEXT_PUBLIC_BRADBURY_PITCH_WARS=
# NEXT_PUBLIC_BRADBURY_JOKE_WARS=
# NEXT_PUBLIC_BRADBURY_EXCUSE_WARS=
# NEXT_PUBLIC_BRADBURY_PREDICTION_WARS=
# NEXT_PUBLIC_BRADBURY_STORY_WARS=
